{
	"name": "nRF5_SDK_Libraries",
	"description": "Libraries for Nordic Semiconductor nRF family",
	"vendor": "Nordic Semiconductor",
	"version": "14.2.0",
	"url": "https://github.com/unsi9ned/",
	"conditions": [
		{
			"id": "nRF51",
			"description": "Nordic Semiconductor nRF51 Series",
			"devices": [
				"nRF51422_xxAA",
				"nRF51422_xxAB",
				"nRF51422_xxAC",
				"nRF51801_xxAB",
				"nRF51802_xxAA",
				"nRF51822_xxAA",
				"nRF51822_xxAB",
				"nRF51822_xxAC",
				"nRF51824_xxAA"
			]
		},
		{
			"id": "nRF52",
			"description": "Nordic Semiconductor nRF52 Series",
			"devices": [
				"nRF52810_xxAA",
				"nRF52832_xxAA",
				"nRF52832_xxAB",
				"nRF52840_xxAA"
			]
		}
	],
	"components": [
		{
			"name": "CMSIS_Core",
			"class": "CMSIS",
			"group": "CORE",
			"version": "5.6.0",
			"external": true
		},
		{
			"name": "sdk_config",
			"description": "SDK configuration",
			"class": "nRF_Drivers",
			"group": "Peripheral",
			"version": "14.2.0",
			"external": true
		},
		{
			"name": "nrf_error",
			"description": "Definitions of error codes",
			"class": "nRF_Drivers",
			"group": "Peripheral",
			"version": "14.2.0",
			"external": true
		},
		{
			"name": "app_error",
			"description": "Various types and definitions available to all applications",
			"class": "nRF_Libraries",
			"group": "Peripheral",
			"version": "14.2.0",
			"files": [
				"components/libraries/util/app_error.c",
				"components/libraries/util/app_error.h",
				"components/libraries/util/sdk_errors.h",
				"components/libraries/util/app_error_weak.h",
				"components/libraries/util/nordic_common.h"
			],
			"requires": [
				{
					"name": "CMSIS_Core",
					"version": "5.6.0"
				},
				{
					"name": "sdk_config",
					"version": "14.2.0"
				},
				{
					"name": "nrf_error",
					"version": "14.2.0"
				}
			],
			"conditions": [
				"nRF51",
				"nRF52"
			]
		},
		{
			"name": "nrf_assert",
			"description": "Utilities for verifying program logic",
			"class": "nRF_Libraries",
			"group": "Peripheral",
			"version": "14.2.0",
			"files": [
				"components/libraries/util/nrf_assert.c",
				"components/libraries/util/nrf_assert.h"
			],
			"requires": [
				{
					"name": "CMSIS_Core",
					"version": "5.6.0"
				},
				{
					"name": "app_error",
					"version": "14.2.0"
				}
			],
			"conditions": [
				"nRF51",
				"nRF52"
			]
		},
		{
			"name": "app_util",
			"description": "Utilities for verifying program logic",
			"class": "nRF_Libraries",
			"group": "Peripheral",
			"version": "14.2.0",
			"files": [
				"components/libraries/util/app_util_platform.c",
				"components/libraries/util/app_util_platform.h",
				"components/libraries/util/app_util_bds.h",
				"components/libraries/util/app_util.h"
			],
			"requires": [
				{
					"name": "CMSIS_Core",
					"version": "5.6.0"
				}
			],
			"conditions": [
				"nRF51",
				"nRF52"
			]
		}
	]
}